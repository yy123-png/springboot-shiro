<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yy.shirosecurity.base.mapper.UserMapper">
    <select id="getByUsername" resultType="com.yy.shirosecurity.base.entity.User">
        SELECT
            id,
            username,
            PASSWORD,
            create_by,
            create_time,
            update_by,
            update_time
        FROM
            tb_user
        WHERE
            username = #{username}
    </select>
</mapper>
